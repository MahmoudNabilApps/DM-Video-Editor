<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0A">

    <!-- TOP TOOLBAR -->
    <LinearLayout
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:minHeight="52dp"
        android:background="#0F0F0F"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="4dp"
        android:paddingEnd="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btnHome"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Back"
            android:padding="10dp"
            android:src="@drawable/ic_close_24" />

        <TextView
            android:id="@+id/tvVideoName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ellipsize="middle"
            android:gravity="center"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"
            android:singleLine="true"
            android:text="Video Editor"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvDuration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:paddingEnd="6dp"
            android:text="00:00 / 00:00"
            android:textColor="#888888"
            android:textSize="10sp" />

        <ImageButton
            android:id="@+id/btnUndo"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:alpha="0.8"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Undo"
            android:padding="5dp"
            android:src="@android:drawable/ic_menu_revert" />

        <ImageButton
            android:id="@+id/btnRedo"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:alpha="0.8"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Redo"
            android:padding="5dp"
            android:src="@drawable/ic_redo_24" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSave"
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_marginStart="4dp"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:text="تصدير"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:textStyle="bold"
            app:backgroundTint="#FF7A00"
            app:cornerRadius="18dp" />

    </LinearLayout>

    <!-- CATEGORY TABS BAR — fixed at bottom -->
    <HorizontalScrollView
        android:id="@+id/categoryBarScroll"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:minHeight="60dp"
        android:background="#0F0F0F"
        android:scrollbars="none"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="4dp"
            android:paddingEnd="4dp">

            <LinearLayout android:id="@+id/catEdit"
                android:layout_width="72dp" android:layout_height="match_parent"
                android:background="@drawable/bg_category_normal"
                android:clickable="true" android:focusable="true"
                android:gravity="center" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="&#x2702;" android:textColor="#FF7A00" android:textSize="20sp" android:gravity="center"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginTop="2dp" android:text="تعديل" android:textColor="#FF7A00" android:textSize="10sp"/>
                <View android:layout_width="20dp" android:layout_height="2dp"
                    android:layout_marginTop="3dp" android:background="#FF7A00"/>
            </LinearLayout>

            <LinearLayout android:id="@+id/catAudio"
                android:layout_width="72dp" android:layout_height="match_parent"
                android:background="@drawable/bg_category_normal"
                android:clickable="true" android:focusable="true"
                android:gravity="center" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="&#x1F3B5;" android:textSize="20sp" android:gravity="center"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginTop="2dp" android:text="صوت" android:textColor="#888888" android:textSize="10sp"/>
                <View android:layout_width="20dp" android:layout_height="2dp"
                    android:layout_marginTop="3dp" android:background="#00000000"/>
            </LinearLayout>

            <LinearLayout android:id="@+id/catText"
                android:layout_width="72dp" android:layout_height="match_parent"
                android:background="@drawable/bg_category_normal"
                android:clickable="true" android:focusable="true"
                android:gravity="center" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="T" android:textColor="#888888" android:textSize="22sp"
                    android:textStyle="bold" android:gravity="center"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginTop="2dp" android:text="نص" android:textColor="#888888" android:textSize="10sp"/>
                <View android:layout_width="20dp" android:layout_height="2dp"
                    android:layout_marginTop="3dp" android:background="#00000000"/>
            </LinearLayout>

            <LinearLayout android:id="@+id/catSticker"
                android:layout_width="72dp" android:layout_height="match_parent"
                android:background="@drawable/bg_category_normal"
                android:clickable="true" android:focusable="true"
                android:gravity="center" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="&#x1F60A;" android:textSize="20sp" android:gravity="center"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginTop="2dp" android:text="ملصقات" android:textColor="#888888" android:textSize="10sp"/>
                <View android:layout_width="20dp" android:layout_height="2dp"
                    android:layout_marginTop="3dp" android:background="#00000000"/>
            </LinearLayout>

            <LinearLayout android:id="@+id/catEffects"
                android:layout_width="72dp" android:layout_height="match_parent"
                android:background="@drawable/bg_category_normal"
                android:clickable="true" android:focusable="true"
                android:gravity="center" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="&#x2728;" android:textSize="20sp" android:gravity="center"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginTop="2dp" android:text="مؤثرات" android:textColor="#888888" android:textSize="10sp"/>
                <View android:layout_width="20dp" android:layout_height="2dp"
                    android:layout_marginTop="3dp" android:background="#00000000"/>
            </LinearLayout>

            <LinearLayout android:id="@+id/catFilter"
                android:layout_width="72dp" android:layout_height="match_parent"
                android:background="@drawable/bg_category_normal"
                android:clickable="true" android:focusable="true"
                android:gravity="center" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="&#x1F3A8;" android:textSize="20sp" android:gravity="center"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginTop="2dp" android:text="فلتر" android:textColor="#888888" android:textSize="10sp"/>
                <View android:layout_width="20dp" android:layout_height="2dp"
                    android:layout_marginTop="3dp" android:background="#00000000"/>
            </LinearLayout>

            <LinearLayout android:id="@+id/catAdjust"
                android:layout_width="72dp" android:layout_height="match_parent"
                android:background="@drawable/bg_category_normal"
                android:clickable="true" android:focusable="true"
                android:gravity="center" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="&#x2600;" android:textSize="20sp" android:gravity="center"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginTop="2dp" android:text="ضبط" android:textColor="#888888" android:textSize="10sp"/>
                <View android:layout_width="20dp" android:layout_height="2dp"
                    android:layout_marginTop="3dp" android:background="#00000000"/>
            </LinearLayout>

            <LinearLayout android:id="@+id/catCanvas"
                android:layout_width="72dp" android:layout_height="match_parent"
                android:background="@drawable/bg_category_normal"
                android:clickable="true" android:focusable="true"
                android:gravity="center" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="&#x1F5BC;" android:textSize="20sp" android:gravity="center"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginTop="2dp" android:text="لوحة" android:textColor="#888888" android:textSize="10sp"/>
                <View android:layout_width="20dp" android:layout_height="2dp"
                    android:layout_marginTop="3dp" android:background="#00000000"/>
            </LinearLayout>

        </LinearLayout>
    </HorizontalScrollView>

    <!-- DIVIDER between category and sub-tools -->
    <View
        android:id="@+id/subToolsCategoryDivider"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="#2A2A2A"
        app:layout_constraintBottom_toTopOf="@id/categoryBarScroll"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- SUB-TOOLS PANEL -->
    <HorizontalScrollView
        android:id="@+id/subToolsScroll"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:minHeight="80dp"
        android:background="#181818"
        android:scrollbars="none"
        app:layout_constraintBottom_toTopOf="@id/subToolsCategoryDivider"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:id="@+id/subToolsContainer"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="8dp"
            android:paddingEnd="8dp" />

    </HorizontalScrollView>

    <!-- TIMELINE (multi-track) -->
    <com.DM.VideoEditor.customviews.MultiTrackTimelineView
        android:id="@+id/multiTrackTimeline"
        android:layout_width="0dp"
        android:layout_height="180dp"
        app:layout_constraintBottom_toTopOf="@id/subToolsScroll"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- PLAY CONTROL BAR -->
    <LinearLayout
        android:id="@+id/playControlBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:minHeight="38dp"
        android:background="#0F0F0F"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        app:layout_constraintBottom_toTopOf="@id/multiTrackTimeline"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <TextView
            android:id="@+id/tvCurrentTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:text="00:00"
            android:textColor="#FF7A00"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btnZoomOut"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginStart="12dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:text="−"
            android:textColor="#666666"
            android:textSize="20sp"
            android:textStyle="bold" />

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <!-- PLAY/PAUSE in center of control bar -->
        <ImageButton
            android:id="@+id/btnPlayPause"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="#33FFFFFF"
            android:contentDescription="Play / Pause"
            android:padding="10dp"
            android:src="@android:drawable/ic_media_play" />

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/btnZoomIn"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginEnd="12dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:text="+"
            android:textColor="#666666"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvTotalTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:text="00:00"
            android:textColor="#555555"
            android:textSize="12sp" />

    </LinearLayout>

    <!-- VIDEO PLAYER — takes all remaining space -->
    <androidx.media3.ui.PlayerView
        android:id="@+id/playerView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#000000"
        app:layout_constraintBottom_toTopOf="@id/playControlBar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintHeight_default="spread"
        app:resize_mode="fit"
        app:use_controller="false" />

    <!-- TEXT OVERLAY PREVIEW (same bounds as PlayerView) -->
    <FrameLayout
        android:id="@+id/textPreviewContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clickable="false"
        android:importantForAccessibility="noHideDescendants"
        app:layout_constraintBottom_toTopOf="@id/playControlBar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHeight_default="spread"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar" />

    <!-- ══ HIDDEN ANCHORS (ViewBinding compatibility) ══ -->
    <LinearLayout android:id="@+id/textOverlayPanel"
        android:layout_width="0dp" android:layout_height="0dp"
        android:orientation="vertical" android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAddTextOverlay"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content" android:layout_height="32dp"
            android:text="+ Add" android:textColor="#FF7A00" android:textSize="12sp"/>
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvTextOverlays"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false"/>
    </LinearLayout>

    <LinearLayout android:id="@+id/timelineContainer"
        android:layout_width="0dp" android:layout_height="0dp"
        android:orientation="vertical" android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">
        <FrameLayout android:layout_width="match_parent" android:layout_height="1dp">
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/frameRecyclerView"
                android:layout_width="match_parent" android:layout_height="match_parent"/>
            <com.DM.VideoEditor.customviews.CustomVideoSeeker
                android:id="@+id/customVideoSeeker"
                android:layout_width="match_parent" android:layout_height="match_parent"/>
        </FrameLayout>
    </LinearLayout>

    <LinearLayout android:id="@+id/clipsTimeline"
        android:layout_width="0dp" android:layout_height="0dp"
        android:orientation="vertical" android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:gravity="center_vertical" android:orientation="horizontal"
            android:paddingStart="12dp" android:paddingEnd="12dp">
            <TextView android:id="@+id/tvClipCount"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textColor="#555555" android:textSize="10sp"/>
            <TextView android:id="@+id/tvTextBadge"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:background="#FF7A00" android:paddingStart="6dp" android:paddingEnd="6dp"
                android:paddingTop="2dp" android:paddingBottom="2dp"
                android:textColor="#FFFFFF" android:textSize="10sp" android:visibility="gone"/>
        </LinearLayout>
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvClips"
            android:layout_width="match_parent" android:layout_height="1dp"/>
    </LinearLayout>

    <!-- LOADING OVERLAY -->
    <include
        android:id="@+id/loadingScreen"
        layout="@layout/loading_screen"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
