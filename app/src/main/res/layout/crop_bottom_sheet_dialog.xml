<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@color/colorBottomSheet">

    <View android:layout_width="40dp" android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:background="#44FFFFFF"
        android:layout_marginBottom="20dp"/>

    <TextView android:id="@+id/tvTitleCrop"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Select Aspect Ratio"
        android:textColor="@color/colorOnPrimary"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="24dp"/>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="28dp">

        <!-- 16:9 -->
        <FrameLayout android:id="@+id/frameAspectRatio1"
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:layout_marginEnd="12dp"
            android:background="@drawable/bg_import_card"
            android:clickable="true" android:focusable="true">
            <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                android:orientation="vertical" android:gravity="center">
                <View android:layout_width="56dp" android:layout_height="32dp"
                    android:background="@drawable/bg_add_button"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="16:9" android:textColor="@color/colorOnPrimary"
                    android:textSize="12sp" android:layout_marginTop="8dp"/>
            </LinearLayout>
        </FrameLayout>

        <!-- 9:16 -->
        <FrameLayout android:id="@+id/frameAspectRatio2"
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:layout_marginEnd="12dp"
            android:background="@drawable/bg_import_card"
            android:clickable="true" android:focusable="true">
            <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                android:orientation="vertical" android:gravity="center">
                <View android:layout_width="36dp" android:layout_height="54dp"
                    android:background="@drawable/bg_add_button"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="9:16" android:textColor="@color/colorOnPrimary"
                    android:textSize="12sp" android:layout_marginTop="8dp"/>
            </LinearLayout>
        </FrameLayout>

        <!-- 1:1 -->
        <FrameLayout android:id="@+id/frameAspectRatio3"
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:background="@drawable/bg_import_card"
            android:clickable="true" android:focusable="true">
            <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                android:orientation="vertical" android:gravity="center">
                <View android:layout_width="44dp" android:layout_height="44dp"
                    android:background="@drawable/bg_add_button"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="1:1" android:textColor="@color/colorOnPrimary"
                    android:textSize="12sp" android:layout_marginTop="8dp"/>
            </LinearLayout>
        </FrameLayout>

    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnCancelCrop"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="Cancel"
        android:textSize="15sp"
        app:cornerRadius="26dp"/>

</LinearLayout>
