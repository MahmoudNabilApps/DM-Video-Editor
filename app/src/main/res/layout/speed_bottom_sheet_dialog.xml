<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@color/colorBottomSheet">

    <!-- Handle indicator -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="20dp"
        android:background="#44FFFFFF" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Playback Speed"
        android:textColor="@color/colorOnPrimary"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <!-- Live speed value display -->
    <TextView
        android:id="@+id/tvSpeedValue"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="1.0×"
        android:textColor="@color/colorAccentLight"
        android:textSize="32sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="16dp" />

    <!-- Speed preset buttons — all wired up in VideoEditingActivity.showSpeedSheet() -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="16dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn025x"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="0.25×"
            android:textSize="11sp"
            android:layout_marginEnd="6dp"
            app:cornerRadius="18dp"
            app:strokeColor="@color/colorAccent" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn05x"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="0.5×"
            android:textSize="11sp"
            android:layout_marginEnd="6dp"
            app:cornerRadius="18dp"
            app:strokeColor="@color/colorAccent" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn1x"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="1×"
            android:textSize="11sp"
            android:layout_marginEnd="6dp"
            app:backgroundTint="@color/colorAccent"
            app:cornerRadius="18dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn2x"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="2×"
            android:textSize="11sp"
            android:layout_marginEnd="6dp"
            app:cornerRadius="18dp"
            app:strokeColor="@color/colorAccent" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn4x"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="4×"
            android:textSize="11sp"
            app:cornerRadius="18dp"
            app:strokeColor="@color/colorAccent" />

    </LinearLayout>

    <!-- Fine-grained slider: 0.25 → 4.0 in steps of 0.25 -->
    <com.google.android.material.slider.Slider
        android:id="@+id/speedSlider"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:valueFrom="0.25"
        android:valueTo="4.0"
        android:value="1.0"
        android:stepSize="0.25"
        app:trackColorActive="@color/colorAccent"
        app:thumbColor="@color/colorAccent"
        app:trackColorInactive="@color/colorSurfaceVariant"
        android:layout_marginBottom="24dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnDoneSpeed"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="Apply Speed"
        android:textSize="15sp"
        app:backgroundTint="@color/colorAccent"
        app:cornerRadius="26dp" />

</LinearLayout>
