<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@color/colorBottomSheet">

    <!-- Handle indicator -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:background="#44FFFFFF"
        android:layout_marginBottom="20dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Add Text Overlay"
        android:textColor="@color/colorOnPrimary"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="20dp" />

    <!-- Text input -->
    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Enter text…"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_marginBottom="16dp"
        app:boxStrokeColor="@color/colorAccent"
        app:hintTextColor="@color/colorAccentLight">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etTextInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/colorOnPrimary"
            android:inputType="text" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Font size input -->
    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:hint="Font size"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        app:boxStrokeColor="@color/colorAccent"
        app:hintTextColor="@color/colorAccentLight">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/fontSize"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/colorOnPrimary"
            android:inputType="number"
            android:text="36" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Position label -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Position"
        android:textColor="@color/colorOnSecondary"
        android:textSize="12sp"
        android:layout_marginBottom="8dp" />

    <!-- Position spinner — outside TextInputLayout for correct rendering -->
    <Spinner
        android:id="@+id/spinnerTextPosition"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:background="@drawable/bg_import_card"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:layout_marginBottom="24dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnDoneText"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="Add Text"
        android:textSize="15sp"
        app:backgroundTint="@color/colorAccent"
        app:cornerRadius="26dp" />

</LinearLayout>
