<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#16213E">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/tvSheetTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="إضافة نص"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <!-- Text input -->
        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="اكتب النص هنا"
            android:layout_marginBottom="12dp"
            app:boxStrokeColor="#00C8FF"
            app:hintTextColor="#00C8FF">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etTextInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:inputType="textMultiLine"
                android:lines="2" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Font size -->
        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="حجم الخط (مثال: 36)"
            android:layout_marginBottom="12dp"
            app:boxStrokeColor="#00C8FF"
            app:hintTextColor="#888888">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/fontSize"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:inputType="number"
                android:text="36" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Color chips -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="لون النص:"
            android:textColor="#AAAAAA"
            android:textSize="12sp"
            android:layout_marginBottom="6dp" />
        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chipGroupColor"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:singleSelection="true" />

        <!-- Position spinner -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="موضع النص:"
            android:textColor="#AAAAAA"
            android:textSize="12sp"
            android:layout_marginBottom="6dp" />
        <Spinner
            android:id="@+id/spinnerTextPosition"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="#1E1E3A"
            android:layout_marginBottom="12dp" />

        <!-- Time range -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:hint="من (ثانية)"
                app:boxStrokeColor="#00C8FF"
                app:hintTextColor="#888888">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etTextStart"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#FFFFFF"
                    android:inputType="numberDecimal"
                    android:hint="0" />
            </com.google.android.material.textfield.TextInputLayout>
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="إلى (ثانية)"
                app:boxStrokeColor="#00C8FF"
                app:hintTextColor="#888888">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etTextEnd"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#FFFFFF"
                    android:inputType="numberDecimal"
                    android:hint="كامل الفيديو" />
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDoneText"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="إضافة النص ✓"
            app:backgroundTint="#00C8FF"
            android:textColor="#000000"
            android:textStyle="bold"
            app:cornerRadius="8dp" />

    </LinearLayout>
</ScrollView>
